\setbeamercolor*{normal text}{fg=percona-2026black}
\setbeamercolor*{title page header}{fg=percona-2026black}
\setbeamercolor*{subtitle}{fg=percona-2026black}
\setbeamercolor*{author}{fg=percona-2026black}
\setbeamercolor*{institute}{fg=percona-2026black}
\setbeamercolor*{ty}{fg=percona-2026white}
\setbeamercolor*{date}{fg=percona-2026black}
\setbeamercolor{section}{fg=white,bg=}
\setbeamercolor{subsection}{fg=white,bg=}
\setbeamercolor*{frametitle}{fg=percona-2026black}
\setbeamercolor*{copyright}{fg=percona-2026tint4}

%List markers
\setbeamercolor*{itemize item}{fg=percona-2026black}
\setbeamercolor*{itemize subitem}{fg=percona-2026black}
\setbeamercolor*{itemize subsubitem}{fg=percona-2026black}
%List text
\setbeamercolor{itemize/enumerate body}{fg=percona-2026black}
\setbeamercolor{itemize/enumerate subbody}{fg=percona-2026black}
\setbeamercolor{itemize/enumerate subsubbody}{fg=percona-2026black}

\setbeamercolor*{section in toc}{fg=percona-2026black}
\setbeamercolor*{subsection in toc}{fg=percona-2026black}

\hypersetup{
  colorlinks=true,
  linkcolor=,
  urlcolor=percona-2026blue
}

