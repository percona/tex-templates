\definecolor{percona-2026white}{RGB}{255,255,255}
\colorlet{percona-2026tint1}{percona-2026blue!10}
\colorlet{percona-2026tint2}{percona-2026blue!20}
\colorlet{percona-2026tint3}{percona-2026black!10}
\colorlet{percona-2026tint4}{percona-2026black!20}
\definecolor{percona-2026mysql}{RGB}{230,90,21}
\definecolor{percona-2026redis}{RGB}{214,54,42}
